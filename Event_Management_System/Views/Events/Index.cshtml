@model IEnumerable<Event_Management_System.Models.Event>
@{
    ViewBag.Title = "Events";
}

<style>
    /* ── Page Header ─────────────────────────── */
    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid rgba(124,58,237,.2);
    }

    .page-label {
        font-size: .68rem;
        font-weight: 600;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--magenta);
        font-family: var(--font-head);
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: .35rem;
    }

        .page-label::before {
            content: '';
            display: block;
            width: 20px;
            height: 1px;
            background: var(--magenta);
        }

    .page-header h2 {
        font-family: var(--font-head);
        font-size: 1.9rem;
        font-weight: 800;
        color: var(--text-white);
        letter-spacing: -.02em;
        line-height: 1.1;
    }

        .page-header h2 span {
            background: linear-gradient(135deg, #c4a7ff, var(--magenta));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

    .btn-add {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        padding: .6rem 1.3rem;
        background: linear-gradient(135deg, var(--purple-main), var(--magenta));
        color: #fff;
        font-family: var(--font-head);
        font-size: .82rem;
        font-weight: 700;
        border-radius: 50px;
        text-decoration: none;
        box-shadow: 0 0 20px rgba(124,58,237,.4);
        transition: all .25s var(--ease);
        white-space: nowrap;
    }

        .btn-add:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 32px rgba(124,58,237,.6);
            color: #fff;
            text-decoration: none;
        }

    /* ── Search / Filter Bar ─────────────────── */
    .toolbar {
        display: flex;
        align-items: center;
        gap: .75rem;
        margin-bottom: 1.25rem;
        flex-wrap: wrap;
    }

    .search-wrap {
        position: relative;
        flex: 1;
        min-width: 200px;
        max-width: 340px;
    }

        .search-wrap i {
            position: absolute;
            left: .85rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-dim);
            font-size: .8rem;
            pointer-events: none;
        }

    .search-input {
        width: 100%;
        padding: .52rem 1rem .52rem 2.25rem;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(124,58,237,.22);
        border-radius: 50px;
        color: var(--text-white);
        font-family: var(--font-body);
        font-size: .82rem;
        outline: none;
        transition: border-color .22s, box-shadow .22s;
    }

        .search-input:focus {
            border-color: var(--purple-main);
            box-shadow: 0 0 0 3px rgba(124,58,237,.12);
        }

        .search-input::placeholder {
            color: var(--text-dim);
        }

    .result-count {
        font-family: var(--font-head);
        font-size: .75rem;
        color: var(--text-dim);
        margin-left: auto;
    }

        .result-count strong {
            color: #c4a7ff;
            font-weight: 700;
        }

    /* ── Empty State ─────────────────────────── */
    .empty-state {
        text-align: center;
        padding: 5rem 2rem;
        background: rgba(255,255,255,.02);
        border: 1px dashed rgba(124,58,237,.25);
        border-radius: 16px;
    }

    .empty-state-icon {
        font-size: 2.5rem;
        opacity: .3;
        margin-bottom: 1rem;
    }

    .empty-state p {
        color: var(--text-muted);
        font-size: .9rem;
        margin-bottom: 1.25rem;
    }

    /* ── Events Table ────────────────────────── */
    .events-panel {
        background: rgba(255,255,255,.025);
        border: 1px solid rgba(124,58,237,.2);
        border-radius: 16px;
        overflow: hidden;
    }

    .events-table {
        width: 100%;
        border-collapse: collapse;
    }

        /* Table Head */
        .events-table thead tr {
            background: rgba(124,58,237,.08);
            border-bottom: 1px solid rgba(124,58,237,.2);
        }

        .events-table thead th {
            font-family: var(--font-head);
            font-size: .65rem;
            font-weight: 600;
            letter-spacing: .18em;
            text-transform: uppercase;
            color: var(--text-dim);
            padding: .85rem 1.25rem;
            text-align: left;
        }

            .events-table thead th:last-child {
                text-align: right;
            }

        /* Table Body */
        .events-table tbody tr {
            border-bottom: 1px solid rgba(255,255,255,.04);
            transition: background .18s var(--ease);
        }

            .events-table tbody tr:last-child {
                border-bottom: none;
            }

            .events-table tbody tr:hover {
                background: rgba(124,58,237,.06);
            }

        .events-table td {
            padding: .9rem 1.25rem;
            vertical-align: middle;
        }

    /* Row number */
    .row-num {
        font-family: var(--font-head);
        font-size: .72rem;
        font-weight: 700;
        color: var(--text-dim);
        width: 40px;
    }

    /* Event name cell */
    .event-name-cell {
        display: flex;
        align-items: center;
        gap: .85rem;
    }

    .event-icon {
        width: 38px;
        height: 38px;
        border-radius: 9px;
        display: grid;
        place-items: center;
        font-size: .9rem;
        flex-shrink: 0;
        background: rgba(124,58,237,.12);
        border: 1px solid rgba(124,58,237,.2);
        color: #c4a7ff;
    }

    .event-name {
        font-family: var(--font-head);
        font-size: .9rem;
        font-weight: 700;
        color: var(--text-white);
    }

    .event-sublabel {
        font-size: .7rem;
        color: var(--text-dim);
        margin-top: .1rem;
    }

    /* Actions cell */
    .actions-cell {
        text-align: right;
        white-space: nowrap;
    }

    .action-btn {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        font-family: var(--font-head);
        font-size: .72rem;
        font-weight: 600;
        border-radius: 50px;
        padding: .32rem .8rem;
        text-decoration: none;
        transition: all .22s var(--ease);
        border: 1px solid transparent;
        margin-left: .35rem;
    }

    .action-btn--edit {
        color: #6ee7b7;
        background: rgba(110,231,183,.08);
        border-color: rgba(110,231,183,.2);
    }

        .action-btn--edit:hover {
            background: rgba(110,231,183,.18);
            border-color: rgba(110,231,183,.5);
            transform: translateY(-1px);
            color: #6ee7b7;
            text-decoration: none;
        }

    .action-btn--delete {
        color: #fca5a5;
        background: rgba(252,165,165,.08);
        border-color: rgba(252,165,165,.2);
    }

        .action-btn--delete:hover {
            background: rgba(252,165,165,.18);
            border-color: rgba(252,165,165,.5);
            transform: translateY(-1px);
            color: #fca5a5;
            text-decoration: none;
        }

    /* ── Table Footer ────────────────────────── */
    .table-footer {
        padding: .85rem 1.25rem;
        background: rgba(124,58,237,.04);
        border-top: 1px solid rgba(124,58,237,.12);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: .5rem;
    }

    .table-footer-text {
        font-family: var(--font-head);
        font-size: .72rem;
        color: var(--text-dim);
    }

        .table-footer-text strong {
            color: #c4a7ff;
        }

    /* ── Responsive ─────────────────────────── */
    @@media (max-width: 600px) {
        .events-table thead th.hide-mobile,
        .events-table td.hide-mobile {
            display: none;
        }

        .toolbar {
            flex-direction: column;
            align-items: stretch;
        }

        .search-wrap {
            max-width: 100%;
        }

        .result-count {
            margin-left: 0;
        }
    }
</style>

<div style="max-width:1200px;margin:0 auto;">

    <!-- Page Header -->
    <div class="page-header">
        <div>
            <div class="page-label">Management</div>
            <h2>Event <span>Directory</span></h2>
        </div>
        <a href="@Url.Action("Create","Events")" class="btn-add">
            <i class="fa fa-plus"></i>
            Add New Event
        </a>
    </div>

    @{
        var eventList = Model.ToList();
        int total = eventList.Count;
    }

    @if (total == 0)
    {
        <!-- Empty State -->
        <div class="empty-state">
            <div class="empty-state-icon"><i class="fa fa-calendar-o"></i></div>
            <p>No events found. Create your first event to get started.</p>
            <a href="@Url.Action("Create","Events")" class="btn-add" style="display:inline-flex;">
                <i class="fa fa-plus"></i> Create First Event
            </a>
        </div>
    }
    else
    {
        <!-- Toolbar -->
        <div class="toolbar">
            <div class="search-wrap">
                <i class="fa fa-search"></i>
                <input type="text" id="eventSearch" class="search-input" placeholder="Search events…" />
            </div>
            <div class="result-count">
                Showing <strong id="visibleCount">@total</strong> of <strong>@total</strong> events
            </div>
        </div>

        <!-- Events Table -->
        <div class="events-panel">
            <table class="events-table" id="eventsTable">
                <thead>
                    <tr>
                        <th style="width:50px;" class="hide-mobile">#</th>
                        <th>Event Name</th>
                        <th style="width:130px;text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int rowNum = 1; }
                    @foreach (var item in eventList)
                    {
                        <tr class="event-row">
                            <td class="row-num hide-mobile">@rowNum</td>
                            <td>
                                <div class="event-name-cell">
                                    <div class="event-icon">
                                        <i class="fa fa-calendar"></i>
                                    </div>
                                    <div>
                                        <div class="event-name">@Html.DisplayFor(m => item.EventName)</div>
                                        <div class="event-sublabel">Event #@item.EventId</div>
                                    </div>
                                </div>
                            </td>
                            <td class="actions-cell">
                                <a href="@Url.Action("Edit","Events", new { id = item.EventId })"
                                   class="action-btn action-btn--edit" title="Edit">
                                    <i class="fa fa-pencil"></i> Edit
                                </a>
                                <a href="@Url.Action("Delete","Events", new { id = item.EventId })"
                                   class="action-btn action-btn--delete" title="Delete">
                                    <i class="fa fa-trash"></i> Delete
                                </a>
                            </td>
                        </tr>
                        rowNum++;
                    }
                </tbody>
            </table>

            <!-- Table Footer -->
            <div class="table-footer">
                <span class="table-footer-text">
                    Total: <strong>@total</strong> event@(total == 1 ? "" : "s")
                </span>
                <span class="table-footer-text">Elite Moments · Event Management</span>
            </div>
        </div>
    }

</div>

<script>/* Live search filter */
    (function () {
        var input = document.getElementById('eventSearch');
        var countEl = document.getElementById('visibleCount');
        if (!input) return;

        input.addEventListener('input', function () {
            var q = this.value.toLowerCase().trim();
            var rows = document.querySelectorAll('#eventsTable .event-row');
            var visible = 0;

            rows.forEach(function (row) {
                var name = row.querySelector('.event-name');
                var match = !q || (name && name.textContent.toLowerCase().includes(q));
                row.style.display = match ? '' : 'none';
                if (match) visible++;
            });

            if (countEl) countEl.textContent = visible;
        });
    })();</script>
