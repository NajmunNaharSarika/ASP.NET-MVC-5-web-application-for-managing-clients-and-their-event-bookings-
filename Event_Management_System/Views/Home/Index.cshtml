@{
    ViewBag.Title = "Home Page";
}

<style>
    /* ── Hero ───────────────────────────────────── */
    .hero {
        position: relative;
        min-height: 88vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        overflow: hidden;
        padding: 5rem 1.5rem 4rem;
    }

    .hero-bg {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 0;
    }

    .hero-orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
        opacity: .55;
    }

    .hero-orb--1 {
        width: 520px; height: 520px;
        top: -120px; left: -120px;
        background: radial-gradient(circle, rgba(124,58,237,.55), transparent 70%);
        animation: orbFloat 8s ease-in-out infinite;
    }

    .hero-orb--2 {
        width: 420px; height: 420px;
        bottom: -80px; right: -80px;
        background: radial-gradient(circle, rgba(233,30,140,.45), transparent 70%);
        animation: orbFloat 10s ease-in-out infinite reverse;
    }

    .hero-orb--3 {
        width: 260px; height: 260px;
        top: 30%; left: 60%;
        background: radial-gradient(circle, rgba(124,58,237,.25), transparent 70%);
        animation: orbFloat 12s ease-in-out infinite 2s;
    }

    @@keyframes orbFloat {
        0%, 100% { transform: translateY(0) scale(1); }
        50%       { transform: translateY(-30px) scale(1.06); }
    }

    /* Floating particles */
    .hero-particles {
        position: absolute;
        inset: 0;
        overflow: hidden;
    }

    .particle {
        position: absolute;
        width: 2px; height: 2px;
        border-radius: 50%;
        background: rgba(255,255,255,.4);
        animation: particleDrift linear infinite;
    }

    @@keyframes particleDrift {
        0%   { transform: translateY(100vh) translateX(0); opacity: 0; }
        10%  { opacity: 1; }
        90%  { opacity: 1; }
        100% { transform: translateY(-20px) translateX(40px); opacity: 0; }
    }

    .hero-content {
        position: relative;
        z-index: 2;
        max-width: 820px;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        background: rgba(124,58,237,.12);
        border: 1px solid rgba(124,58,237,.3);
        border-radius: 50px;
        padding: .35rem 1rem;
        font-family: var(--font-head);
        font-size: .72rem;
        font-weight: 600;
        letter-spacing: .15em;
        text-transform: uppercase;
        color: rgba(196,167,255,.9);
        margin-bottom: 1.75rem;
        animation: fadeUp .6s var(--ease) .1s both;
    }

    .hero-badge .pulse-dot {
        width: 6px; height: 6px;
        background: var(--magenta);
        border-radius: 50%;
        box-shadow: 0 0 8px var(--magenta);
        animation: blink 2s infinite;
    }

    .hero-title {
        font-family: var(--font-head);
        font-size: clamp(2.6rem, 6vw, 5rem);
        font-weight: 800;
        line-height: 1.08;
        letter-spacing: -.02em;
        color: var(--text-white);
        margin-bottom: 1.5rem;
        animation: fadeUp .6s var(--ease) .2s both;
    }

    .hero-title .gradient-text {
        background: linear-gradient(135deg, #c4a7ff 0%, var(--magenta) 60%, #ff9de2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero-sub {
        font-size: 1.05rem;
        color: var(--text-muted);
        line-height: 1.8;
        max-width: 580px;
        margin: 0 auto 2.5rem;
        animation: fadeUp .6s var(--ease) .3s both;
    }

    .hero-cta {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
        animation: fadeUp .6s var(--ease) .4s both;
    }

    .btn-primary-glow {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        padding: .8rem 2rem;
        background: linear-gradient(135deg, var(--purple-main), var(--magenta));
        color: #fff;
        font-family: var(--font-head);
        font-size: .88rem;
        font-weight: 700;
        letter-spacing: .04em;
        border-radius: 50px;
        text-decoration: none;
        box-shadow: 0 0 30px rgba(124,58,237,.5), 0 0 60px rgba(233,30,140,.2);
        transition: all .28s var(--ease);
    }

    .btn-primary-glow:hover {
        transform: translateY(-3px);
        box-shadow: 0 0 40px rgba(124,58,237,.7), 0 0 80px rgba(233,30,140,.3);
        color: #fff;
        text-decoration: none;
    }

    .btn-ghost-glow {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        padding: .8rem 2rem;
        background: rgba(255,255,255,.04);
        color: var(--text-white);
        font-family: var(--font-head);
        font-size: .88rem;
        font-weight: 600;
        letter-spacing: .04em;
        border-radius: 50px;
        border: 1px solid rgba(255,255,255,.15);
        text-decoration: none;
        transition: all .28s var(--ease);
    }

    .btn-ghost-glow:hover {
        background: rgba(124,58,237,.12);
        border-color: rgba(124,58,237,.5);
        transform: translateY(-3px);
        color: #fff;
        text-decoration: none;
    }

    /* ── Stats Bar ─────────────────────────────── */
    .stats-bar {
        position: relative;
        z-index: 2;
        display: flex;
        justify-content: center;
        gap: 0;
        flex-wrap: wrap;
        margin-top: 4rem;
        animation: fadeUp .6s var(--ease) .5s both;
    }

    .stat-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 1.2rem 2.5rem;
        border-right: 1px solid rgba(124,58,237,.2);
    }

    .stat-item:last-child { border-right: none; }

    .stat-num {
        font-family: var(--font-head);
        font-size: 2rem;
        font-weight: 800;
        background: linear-gradient(135deg, #c4a7ff, var(--magenta));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        line-height: 1;
    }

    .stat-label {
        font-size: .72rem;
        color: var(--text-dim);
        text-transform: uppercase;
        letter-spacing: .15em;
        margin-top: .3rem;
        font-family: var(--font-head);
    }

    /* ── Section Heading ────────────────────────── */
    .section-label {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        font-family: var(--font-head);
        font-size: .68rem;
        font-weight: 600;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--magenta);
        margin-bottom: .75rem;
    }

    .section-label::before {
        content: '';
        display: block;
        width: 24px; height: 1px;
        background: var(--magenta);
    }

    .section-title {
        font-family: var(--font-head);
        font-size: clamp(1.6rem, 3.5vw, 2.4rem);
        font-weight: 800;
        line-height: 1.15;
        color: var(--text-white);
        margin-bottom: .75rem;
    }

    .section-desc {
        font-size: .9rem;
        color: var(--text-muted);
        line-height: 1.8;
        max-width: 500px;
    }

    /* ── Feature Cards ──────────────────────────── */
    .features-section {
        padding: 5rem 1.5rem;
        max-width: 1320px;
        margin: 0 auto;
    }

    .features-header {
        text-align: center;
        margin-bottom: 3.5rem;
    }

    .features-header .section-desc {
        margin: 0 auto;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
    }

    .feature-card {
        position: relative;
        background: rgba(255,255,255,.03);
        border: 1px solid rgba(124,58,237,.18);
        border-radius: 16px;
        padding: 2rem;
        overflow: hidden;
        transition: all .3s var(--ease);
        text-decoration: none;
        display: block;
        color: inherit;
    }

    .feature-card::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(124,58,237,.06) 0%, transparent 60%);
        opacity: 0;
        transition: opacity .3s;
    }

    .feature-card:hover {
        transform: translateY(-6px);
        border-color: rgba(124,58,237,.45);
        box-shadow: 0 20px 60px rgba(0,0,0,.4), 0 0 40px rgba(124,58,237,.15);
        text-decoration: none;
        color: inherit;
    }

    .feature-card:hover::before { opacity: 1; }

    .feature-card-glow {
        position: absolute;
        top: -60px; right: -60px;
        width: 160px; height: 160px;
        border-radius: 50%;
        opacity: 0;
        transition: opacity .3s;
        pointer-events: none;
    }

    .feature-card:hover .feature-card-glow { opacity: 1; }

    .feature-icon-wrap {
        width: 52px; height: 52px;
        border-radius: 12px;
        display: grid;
        place-items: center;
        margin-bottom: 1.5rem;
        font-size: 1.3rem;
        position: relative;
        z-index: 1;
    }

    .feature-card h3 {
        font-family: var(--font-head);
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--text-white);
        margin-bottom: .6rem;
        position: relative;
        z-index: 1;
    }

    .feature-card p {
        font-size: .84rem;
        color: var(--text-muted);
        line-height: 1.75;
        position: relative;
        z-index: 1;
        margin-bottom: 1.5rem;
    }

    .feature-link {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        font-family: var(--font-head);
        font-size: .78rem;
        font-weight: 600;
        letter-spacing: .05em;
        text-decoration: none;
        position: relative;
        z-index: 1;
        transition: gap .22s var(--ease);
    }

    .feature-card:hover .feature-link { gap: .7rem; }

    /* ── Services Section ───────────────────────── */
    .services-section {
        padding: 5rem 1.5rem;
        background: rgba(13,9,25,.6);
        border-top: 1px solid rgba(124,58,237,.1);
        border-bottom: 1px solid rgba(124,58,237,.1);
    }

    .services-inner {
        max-width: 1320px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1.6fr;
        gap: 5rem;
        align-items: center;
    }

    .services-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .service-pill {
        display: flex;
        align-items: center;
        gap: .75rem;
        background: rgba(255,255,255,.03);
        border: 1px solid rgba(124,58,237,.15);
        border-radius: 12px;
        padding: 1rem 1.1rem;
        transition: all .25s var(--ease);
        cursor: default;
    }

    .service-pill:hover {
        background: rgba(124,58,237,.08);
        border-color: rgba(124,58,237,.35);
        transform: translateX(4px);
    }

    .service-pill-icon {
        width: 36px; height: 36px;
        border-radius: 8px;
        display: grid;
        place-items: center;
        font-size: .95rem;
        flex-shrink: 0;
    }

    .service-pill-text {
        font-family: var(--font-head);
        font-size: .82rem;
        font-weight: 600;
        color: var(--text-white);
    }

    .service-pill-sub {
        font-size: .7rem;
        color: var(--text-dim);
        margin-top: .1rem;
    }

    /* ── How It Works ───────────────────────────── */
    .how-section {
        padding: 5rem 1.5rem;
        max-width: 1320px;
        margin: 0 auto;
        text-align: center;
    }

    .steps-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
        margin-top: 3.5rem;
        position: relative;
    }

    .steps-grid::before {
        content: '';
        position: absolute;
        top: 28px;
        left: calc(12.5% + 28px);
        right: calc(12.5% + 28px);
        height: 1px;
        background: linear-gradient(90deg, var(--purple-main), var(--magenta));
        opacity: .35;
    }

    .step-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
    }

    .step-num {
        width: 56px; height: 56px;
        border-radius: 50%;
        border: 2px solid rgba(124,58,237,.4);
        background: rgba(124,58,237,.1);
        display: grid;
        place-items: center;
        font-family: var(--font-head);
        font-size: 1.1rem;
        font-weight: 800;
        background: linear-gradient(135deg, var(--purple-main), var(--magenta));
        color: #fff;
        box-shadow: 0 0 20px rgba(124,58,237,.4);
        position: relative;
        z-index: 1;
        flex-shrink: 0;
    }

    .step-card h4 {
        font-family: var(--font-head);
        font-size: .95rem;
        font-weight: 700;
        color: var(--text-white);
    }

    .step-card p {
        font-size: .8rem;
        color: var(--text-muted);
        line-height: 1.7;
    }

    /* ── Testimonials ───────────────────────────── */
    .testimonials-section {
        padding: 5rem 1.5rem;
        background: rgba(13,9,25,.5);
        border-top: 1px solid rgba(124,58,237,.1);
    }

    .testimonials-inner {
        max-width: 1320px;
        margin: 0 auto;
    }

    .testimonials-header {
        text-align: center;
        margin-bottom: 3rem;
    }

    .testimonials-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
    }

    .testimonial-card {
        background: rgba(255,255,255,.03);
        border: 1px solid rgba(124,58,237,.15);
        border-radius: 16px;
        padding: 1.75rem;
        transition: border-color .25s, transform .25s;
    }

    .testimonial-card:hover {
        border-color: rgba(124,58,237,.35);
        transform: translateY(-4px);
    }

    .testimonial-stars {
        display: flex;
        gap: .2rem;
        margin-bottom: 1rem;
    }

    .testimonial-stars i {
        color: #fbbf24;
        font-size: .8rem;
    }

    .testimonial-text {
        font-size: .85rem;
        color: var(--text-muted);
        line-height: 1.8;
        margin-bottom: 1.25rem;
        font-style: italic;
    }

    .testimonial-author {
        display: flex;
        align-items: center;
        gap: .75rem;
    }

    .author-avatar {
        width: 38px; height: 38px;
        border-radius: 50%;
        display: grid;
        place-items: center;
        font-family: var(--font-head);
        font-size: .85rem;
        font-weight: 700;
        color: #fff;
        flex-shrink: 0;
    }

    .author-name {
        font-family: var(--font-head);
        font-size: .85rem;
        font-weight: 700;
        color: var(--text-white);
    }

    .author-role {
        font-size: .72rem;
        color: var(--text-dim);
    }

    /* ── CTA Banner ─────────────────────────────── */
    .cta-section {
        padding: 5rem 1.5rem;
        max-width: 1320px;
        margin: 0 auto;
        text-align: center;
    }

    .cta-box {
        position: relative;
        background: linear-gradient(135deg, rgba(124,58,237,.15) 0%, rgba(233,30,140,.1) 100%);
        border: 1px solid rgba(124,58,237,.3);
        border-radius: 24px;
        padding: 4rem 2rem;
        overflow: hidden;
    }

    .cta-box::before {
        content: '';
        position: absolute;
        inset: -1px;
        border-radius: 24px;
        background: linear-gradient(135deg, rgba(124,58,237,.4), rgba(233,30,140,.3));
        z-index: -1;
        opacity: .4;
    }

    .cta-box h2 {
        font-family: var(--font-head);
        font-size: clamp(1.6rem, 3vw, 2.4rem);
        font-weight: 800;
        color: var(--text-white);
        margin-bottom: .75rem;
    }

    .cta-box p {
        font-size: .95rem;
        color: var(--text-muted);
        max-width: 480px;
        margin: 0 auto 2rem;
        line-height: 1.75;
    }

    .cta-buttons {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    /* ── Responsive ─────────────────────────────── */
    @@media (max-width: 1024px) {
        .features-grid,
        .testimonials-grid { grid-template-columns: repeat(2, 1fr); }
        .steps-grid { grid-template-columns: repeat(2, 1fr); }
        .steps-grid::before { display: none; }
        .services-inner { grid-template-columns: 1fr; gap: 3rem; }
    }

    @@media (max-width: 640px) {
        .features-grid,
        .testimonials-grid,
        .steps-grid,
        .services-grid { grid-template-columns: 1fr; }
        .stat-item { padding: 1rem 1.5rem; }
        .hero { padding: 4rem 1rem 3rem; }
    }
</style>

<!-- ════ HERO ════ -->
<section class="hero">
    <div class="hero-bg">
        <div class="hero-orb hero-orb--1"></div>
        <div class="hero-orb hero-orb--2"></div>
        <div class="hero-orb hero-orb--3"></div>
        <div class="hero-particles" id="heroParticles"></div>
    </div>

    <div class="hero-content">
        <div class="hero-badge">
            <span class="pulse-dot"></span>
            Premium Event Management Platform
        </div>

        <h1 class="hero-title">
            Craft <span class="gradient-text">Unforgettable</span><br />
            Moments, Every Time
        </h1>

        <p class="hero-sub">
            A smart, all-in-one solution for managing events, bookings, and clients.
            From intimate gatherings to grand celebrations — plan, execute, and wow.
        </p>

        <div class="hero-cta">
            <a href="/Clients/Create" class="btn-primary-glow">
                <i class="fa fa-calendar-plus-o"></i>
                Book an Event
            </a>
            <a href="/Events" class="btn-ghost-glow">
                <i class="fa fa-eye"></i>
                Browse Events
            </a>
        </div>

        <div class="stats-bar">
            <div class="stat-item">
                <span class="stat-num">500+</span>
                <span class="stat-label">Events Done</span>
            </div>
            <div class="stat-item">
                <span class="stat-num">98%</span>
                <span class="stat-label">Satisfaction</span>
            </div>
            <div class="stat-item">
                <span class="stat-num">200+</span>
                <span class="stat-label">Happy Clients</span>
            </div>
            <div class="stat-item">
                <span class="stat-num">5★</span>
                <span class="stat-label">Avg Rating</span>
            </div>
        </div>
    </div>
</section>

<!-- ════ FEATURES ════ -->
<section class="features-section">
    <div class="features-header">
        <div class="section-label">What We Offer</div>
        <h2 class="section-title">Everything You Need to<br />Run a Flawless Event</h2>
        <p class="section-desc">Powerful tools designed for event planners who demand perfection. Streamline every step from planning to execution.</p>
    </div>

    <div class="features-grid">
        <!-- Event Planning -->
        <a href="/Events" class="feature-card">
            <div class="feature-card-glow" style="background:radial-gradient(circle,rgba(124,58,237,.3),transparent 70%)"></div>
            <div class="feature-icon-wrap" style="background:rgba(124,58,237,.15);color:#c4a7ff;">
                <i class="fa fa-calendar"></i>
            </div>
            <h3>Event Planning</h3>
            <p>Create and manage events effortlessly. Set schedules, assign teams, and track every activity in one centralized dashboard for smooth execution.</p>
            <span class="feature-link" style="color:#c4a7ff;">
                View Events <i class="fa fa-arrow-right"></i>
            </span>
        </a>

        <!-- Client Management -->
        <a href="/Clients" class="feature-card">
            <div class="feature-card-glow" style="background:radial-gradient(circle,rgba(233,30,140,.25),transparent 70%)"></div>
            <div class="feature-icon-wrap" style="background:rgba(233,30,140,.12);color:#f472b6;">
                <i class="fa fa-users"></i>
            </div>
            <h3>Client Management</h3>
            <p>Store client profiles, track booking history, and maintain lasting relationships through a centralized client management system.</p>
            <span class="feature-link" style="color:#f472b6;">
                Manage Clients <i class="fa fa-arrow-right"></i>
            </span>
        </a>

        <!-- Event Booking -->
        <a href="/Clients/Create" class="feature-card">
            <div class="feature-card-glow" style="background:radial-gradient(circle,rgba(124,58,237,.3),transparent 70%)"></div>
            <div class="feature-icon-wrap" style="background:rgba(124,58,237,.15);color:#c4a7ff;">
                <i class="fa fa-ticket"></i>
            </div>
            <h3>Event Booking</h3>
            <p>Book weddings, conferences, parties and more. Track status in real-time, update details on the fly, and ensure a flawless workflow every time.</p>
            <span class="feature-link" style="color:#c4a7ff;">
                Book Now <i class="fa fa-arrow-right"></i>
            </span>
        </a>
    </div>
</section>

<!-- ════ SERVICES ════ -->
<section class="services-section">
    <div class="services-inner">
        <div>
            <div class="section-label">Our Services</div>
            <h2 class="section-title">Every Occasion,<br />Perfectly Planned</h2>
            <p class="section-desc">We specialise in a wide range of events. No matter the occasion, we bring the same passion and precision to every celebration.</p>
            <div style="margin-top:2rem;">
                <a href="/Clients/Create" class="btn-primary-glow" style="font-size:.82rem;padding:.7rem 1.6rem;">
                    <i class="fa fa-plus"></i>
                    Start Planning
                </a>
            </div>
        </div>

        <div class="services-grid">
            <div class="service-pill">
                <div class="service-pill-icon" style="background:rgba(233,30,140,.12);color:#f472b6;">💍</div>
                <div>
                    <div class="service-pill-text">Wedding</div>
                    <div class="service-pill-sub">Fairytale ceremonies</div>
                </div>
            </div>
            <div class="service-pill">
                <div class="service-pill-icon" style="background:rgba(124,58,237,.12);color:#c4a7ff;">💑</div>
                <div>
                    <div class="service-pill-text">Engagement</div>
                    <div class="service-pill-sub">Romantic proposals</div>
                </div>
            </div>
            <div class="service-pill">
                <div class="service-pill-icon" style="background:rgba(233,30,140,.12);color:#f472b6;">🎂</div>
                <div>
                    <div class="service-pill-text">Birthday Party</div>
                    <div class="service-pill-sub">Memorable milestones</div>
                </div>
