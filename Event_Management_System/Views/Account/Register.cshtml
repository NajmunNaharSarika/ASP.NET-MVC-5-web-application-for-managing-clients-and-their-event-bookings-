@model Event_Management_System.Models.RegisterViewModel
@{
    ViewBag.Title = "Register";
}

<style>
    /* ── Register Specific Styles ────────────────── */
    .auth-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: calc(100vh - var(--nav-h) - 200px);
        padding: 2.5rem 1rem;
    }

    .elite-card {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 2.5rem;
        width: 100%;
        max-width: 550px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

        .elite-card h2 {
            font-family: var(--font-head);
            font-weight: 700;
            margin-bottom: 0.5rem;
            background: linear-gradient(90deg, var(--purple-main), var(--magenta));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .elite-card p {
            color: var(--text-muted);
            font-size: 0.9rem;
            margin-bottom: 2rem;
        }

    /* Form Layout */
    .form-group-elite {
        margin-bottom: 1.25rem;
    }

        .form-group-elite label {
            display: block;
            font-family: var(--font-head);
            font-size: 0.85rem;
            color: var(--text-white);
            margin-bottom: 0.5rem;
            font-weight: 500;
        }

    .elite-input {
        width: 100%;
        padding: 0.8rem 1rem;
        background: rgba(13, 9, 25, 0.6);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        color: white;
        font-size: 0.95rem;
        transition: all 0.2s var(--ease);
    }

        .elite-input:focus {
            outline: none;
            border-color: var(--purple-main);
            box-shadow: 0 0 0 4px var(--purple-glow);
            background: rgba(13, 9, 25, 0.9);
        }

    .btn-elite-primary {
        width: 100%;
        padding: 0.85rem;
        background: linear-gradient(135deg, var(--purple-main), var(--magenta));
        border: none;
        border-radius: var(--radius-sm);
        color: white;
        font-family: var(--font-head);
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.2s, opacity 0.2s, box-shadow 0.2s;
        margin-top: 1rem;
    }

        .btn-elite-primary:hover {
            transform: translateY(-2px);
            opacity: 0.95;
            box-shadow: 0 10px 20px rgba(124, 58, 237, 0.3);
        }

    .auth-footer-links {
        margin-top: 1.5rem;
        text-align: center;
        border-top: 1px solid var(--border);
        padding-top: 1.5rem;
    }

        .auth-footer-links a {
            color: var(--magenta-light);
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 500;
        }

            .auth-footer-links a:hover {
                text-decoration: underline;
            }

    /* Validation Style Override */
    .text-danger {
        font-size: 0.75rem;
        color: #ff4d4d !important;
        margin-top: 0.25rem;
        display: block;
    }
</style>

<div class="auth-container">
    <div class="elite-card">
        <h2>@ViewBag.Title</h2>
        <p>Join the elite. Create your account to start managing unforgettable moments.</p>

        @using (Html.BeginForm("Register", "Account", FormMethod.Post, new { role = "form" }))
        {
            @Html.AntiForgeryToken()

            @Html.ValidationSummary("", new { @class = "text-danger mb-3" })

            <div class="form-group-elite">
                @Html.LabelFor(m => m.Email)
                @Html.TextBoxFor(m => m.Email, new { @class = "elite-input", placeholder = "email@example.com" })
            </div>

            <div class="form-group-elite">
                @Html.LabelFor(m => m.Password)
                @Html.PasswordFor(m => m.Password, new { @class = "elite-input", placeholder = "••••••••" })
            </div>

            <div class="form-group-elite">
                @Html.LabelFor(m => m.ConfirmPassword)
                @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "elite-input", placeholder = "Confirm your password" })
            </div>

            <button type="submit" class="btn-elite-primary">Create Account</button>

            <div class="auth-footer-links">
                <p>Already have an account? @Html.ActionLink("Log in here", "Login")</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}