@model Event_Management_System.Models.View_Model.ClientVM
@{
    ViewBag.Title = "Edit Client";
}

<style>
    /* ── Page Header ─────────────────────────── */
    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid rgba(124,58,237,.2);
    }

    .page-label {
        font-size: .68rem;
        font-weight: 600;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--magenta);
        font-family: var(--font-head);
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: .35rem;
    }

        .page-label::before {
            content: '';
            display: block;
            width: 20px;
            height: 1px;
            background: var(--magenta);
        }

    .page-header h2 {
        font-family: var(--font-head);
        font-size: 1.9rem;
        font-weight: 800;
        color: var(--text-white);
        letter-spacing: -.02em;
        line-height: 1.1;
    }

        .page-header h2 span {
            background: linear-gradient(135deg, #c4a7ff, var(--magenta));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        font-family: var(--font-head);
        font-size: .78rem;
        font-weight: 600;
        color: var(--text-muted);
        text-decoration: none;
        padding: .4rem .9rem;
        border: 1px solid rgba(124,58,237,.25);
        border-radius: 50px;
        transition: all .22s var(--ease);
    }

        .btn-back:hover {
            color: var(--text-white);
            border-color: rgba(124,58,237,.55);
            background: rgba(124,58,237,.1);
            text-decoration: none;
        }

    /* ── Two-Panel Layout ────────────────────── */
    .edit-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.75rem;
        align-items: start;
    }

    /* ── Panel ───────────────────────────────── */
    .panel {
        background: rgba(255,255,255,.025);
        border: 1px solid rgba(124,58,237,.2);
        border-radius: 16px;
        overflow: hidden;
    }

    .panel-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.1rem 1.5rem;
        background: rgba(124,58,237,.07);
        border-bottom: 1px solid rgba(124,58,237,.15);
    }

    .panel-title {
        display: flex;
        align-items: center;
        gap: .6rem;
        font-family: var(--font-head);
        font-size: .95rem;
        font-weight: 700;
        color: var(--text-white);
    }

    .panel-title-icon {
        width: 30px;
        height: 30px;
        border-radius: 7px;
        display: grid;
        place-items: center;
        font-size: .8rem;
        flex-shrink: 0;
    }

    .panel-body {
        padding: 1.5rem;
    }

    /* ── Client Identity Preview ─────────────── */
    .client-identity {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.25rem;
        background: rgba(124,58,237,.06);
        border: 1px solid rgba(124,58,237,.15);
        border-radius: 10px;
        margin-bottom: 1.5rem;
    }

    .identity-avatar {
        width: 52px;
        height: 52px;
        border-radius: 12px;
        object-fit: cover;
        border: 2px solid rgba(124,58,237,.4);
        box-shadow: 0 0 16px rgba(124,58,237,.3);
        flex-shrink: 0;
    }

    .identity-avatar-fallback {
        width: 52px;
        height: 52px;
        border-radius: 12px;
        background: linear-gradient(135deg, var(--purple-main), var(--magenta));
        display: grid;
        place-items: center;
        font-family: var(--font-head);
        font-size: 1.2rem;
        font-weight: 800;
        color: #fff;
        box-shadow: 0 0 16px rgba(124,58,237,.4);
        flex-shrink: 0;
    }

    .identity-info {
        flex: 1;
        min-width: 0;
    }

    .identity-name {
        font-family: var(--font-head);
        font-size: .95rem;
        font-weight: 700;
        color: var(--text-white);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .identity-id {
        font-size: .7rem;
        color: var(--text-dim);
        font-family: var(--font-head);
        margin-top: .15rem;
    }

    .identity-badge {
        font-size: .65rem;
        font-family: var(--font-head);
        font-weight: 600;
        background: rgba(233,30,140,.1);
        border: 1px solid rgba(233,30,140,.25);
        color: #f472b6;
        border-radius: 50px;
        padding: .18rem .65rem;
        white-space: nowrap;
    }

    /* ── Form Fields ─────────────────────────── */
    .field-group {
        margin-bottom: 1.2rem;
    }

    .field-label {
        display: block;
        font-family: var(--font-head);
        font-size: .72rem;
        font-weight: 600;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: .45rem;
    }

    .field-input {
        width: 100%;
        padding: .6rem 1rem;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(124,58,237,.25);
        border-radius: 8px;
        color: var(--text-white);
        font-family: var(--font-body);
        font-size: .85rem;
        outline: none;
        transition: border-color .22s, box-shadow .22s;
        appearance: none;
        -webkit-appearance: none;
    }

        .field-input:focus {
            border-color: var(--purple-main);
            box-shadow: 0 0 0 3px rgba(124,58,237,.15);
        }

        .field-input::placeholder {
            color: var(--text-dim);
        }

        .field-input[type="date"]::-webkit-calendar-picker-indicator {
            filter: invert(.6) sepia(1) saturate(3) hue-rotate(240deg);
            cursor: pointer;
            opacity: .7;
        }

    /* File input with current picture preview */
    .file-field-wrap {
        display: flex;
        flex-direction: column;
        gap: .6rem;
    }

    .current-picture-wrap {
        display: flex;
        align-items: center;
        gap: .6rem;
        padding: .5rem .75rem;
        background: rgba(255,255,255,.03);
        border: 1px solid rgba(124,58,237,.15);
        border-radius: 8px;
    }

        .current-picture-wrap img {
            width: 36px;
            height: 36px;
            border-radius: 7px;
            object-fit: cover;
            border: 1px solid rgba(124,58,237,.3);
        }

    .current-picture-label {
        font-size: .72rem;
        color: var(--text-dim);
        font-family: var(--font-head);
    }

    .field-input[type="file"] {
        padding: .45rem .75rem;
        cursor: pointer;
    }

        .field-input[type="file"]::-webkit-file-upload-button {
            background: linear-gradient(135deg, var(--purple-main), var(--magenta));
            border: none;
            border-radius: 6px;
            color: #fff;
            font-family: var(--font-head);
            font-size: .72rem;
            font-weight: 600;
            padding: .3rem .8rem;
            cursor: pointer;
            margin-right: .75rem;
            transition: opacity .2s;
        }

            .field-input[type="file"]::-webkit-file-upload-button:hover {
                opacity: .85;
            }

    .field-validation {
        font-size: .75rem;
        color: #fca5a5;
        margin-top: .3rem;
        display: block;
    }

    /* ── Marital Status Toggle ───────────────── */
    .toggle-wrap {
        display: flex;
        align-items: center;
        gap: .75rem;
        padding: .6rem 1rem;
        background: rgba(255,255,255,.03);
        border: 1px solid rgba(124,58,237,.2);
        border-radius: 8px;
        cursor: pointer;
        transition: border-color .22s, background .22s;
    }

        .toggle-wrap:hover {
            background: rgba(124,58,237,.07);
            border-color: rgba(124,58,237,.4);
        }

        .toggle-wrap input[type="checkbox"] {
            width: 36px;
            height: 20px;
            -webkit-appearance: none;
            appearance: none;
            background: rgba(255,255,255,.1);
            border: 1px solid rgba(124,58,237,.3);
            border-radius: 50px;
            position: relative;
            cursor: pointer;
            transition: background .22s;
            flex-shrink: 0;
        }

            .toggle-wrap input[type="checkbox"]::before {
                content: '';
                position: absolute;
                top: 2px;
                left: 2px;
                width: 14px;
                height: 14px;
                border-radius: 50%;
                background: rgba(255,255,255,.5);
                transition: transform .22s, background .22s;
            }

            .toggle-wrap input[type="checkbox"]:checked {
                background: linear-gradient(135deg, var(--purple-main), var(--magenta));
                border-color: transparent;
            }

                .toggle-wrap input[type="checkbox"]:checked::before {
                    transform: translateX(16px);
                    background: #fff;
                }

    .toggle-label {
        font-family: var(--font-head);
        font-size: .82rem;
        font-weight: 500;
        color: var(--text-muted);
        user-select: none;
    }

    /* ── Update Button ───────────────────────── */
    .btn-update {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        padding: .65rem 2rem;
        background: linear-gradient(135deg, var(--purple-main), var(--magenta));
        color: #fff;
        font-family: var(--font-head);
        font-size: .85rem;
        font-weight: 700;
        border: none;
        border-radius: 50px;
        cursor: pointer;
        box-shadow: 0 0 24px rgba(124,58,237,.45);
        transition: all .25s var(--ease);
        width: 100%;
        margin-top: .5rem;
    }

        .btn-update:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 36px rgba(124,58,237,.65);
        }

    /* ── Add Event Button ────────────────────── */
    .btn-add-event {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .38rem .9rem;
        background: rgba(124,58,237,.15);
        border: 1px solid rgba(124,58,237,.35);
        border-radius: 50px;
        color: #c4a7ff;
        font-family: var(--font-head);
        font-size: .75rem;
        font-weight: 600;
        text-decoration: none;
        transition: all .22s var(--ease);
    }

        .btn-add-event:hover {
            background: rgba(124,58,237,.28);
            border-color: rgba(124,58,237,.6);
            color: #fff;
            text-decoration: none;
            transform: translateY(-1px);
        }

    /* ── Event Container ─────────────────────── */
    #eventContainer {
        display: flex;
        flex-direction: column;
        gap: .6rem;
    }

    /* ── Message Area ────────────────────────── */
    #msg {
        margin-top: 1rem;
    }

    /* ── Responsive ─────────────────────────── */
    @@media (max-width: 768px) {
        .edit-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div style="max-width:1200px;margin:0 auto;">

    <!-- Page Header -->
    <div class="page-header">
        <div>
            <div class="page-label">Clients</div>
            <h2>Edit <span>Client</span></h2>
        </div>
        <a href="@Url.Action("Index","Clients")" class="btn-back">
            <i class="fa fa-arrow-left"></i> Back to Clients
        </a>
    </div>

    @using (Ajax.BeginForm(new AjaxOptions
    {
        HttpMethod = "POST",
        InsertionMode = InsertionMode.Replace,
        UpdateTargetId = "msg",
        OnComplete = "clearAll"
    }))
    {
        @Html.HiddenFor(x => x.ClientId)
        @Html.HiddenFor(x => x.Picture)

        <div class="edit-grid">

            <!-- ── Left Panel: Client Details ── -->
            <div class="panel">
                <div class="panel-header">
                    <div class="panel-title">
                        <div class="panel-title-icon" style="background:rgba(124,58,237,.2);color:#c4a7ff;">
                            <i class="fa fa-user"></i>
                        </div>
                        Client Details
                    </div>
                    <span class="identity-badge">Editing</span>
                </div>
                <div class="panel-body">

                    <!-- Current client identity preview -->
                    <div class="client-identity">
                        @if (!string.IsNullOrEmpty(Model.Picture))
                        {
                            <img src="@Model.Picture" class="identity-avatar" alt="@Model.ClientName" />
                        }
                        else
                        {
                            <div class="identity-avatar-fallback">
                                @(Model.ClientName != null && Model.ClientName.Length > 0 ? Model.ClientName.Substring(0, 1).ToUpper() : "?")
                            </div>
                        }
                        <div class="identity-info">
                            <div class="identity-name">@Model.ClientName</div>
                            <div class="identity-id">Client ID: #@Model.ClientId</div>
                        </div>
                    </div>

                    <!-- Client Name -->
                    <div class="field-group">
                        @Html.LabelFor(x => x.ClientName, "Client Name", new { @class = "field-label" })
                        @Html.TextBoxFor(x => x.ClientName, new { @class = "field-input", placeholder = "Enter full name" })
                        @Html.ValidationMessageFor(x => x.ClientName, "", new { @class = "field-validation" })
                    </div>

                    <!-- Birth Date -->
                    <div class="field-group">
                        @Html.LabelFor(x => x.BirthDate, "Date of Birth", new { @class = "field-label" })
                        @Html.TextBoxFor(x => x.BirthDate, "{0:yyyy-MM-dd}", new { @class = "field-input", type = "date" })
                        @Html.ValidationMessageFor(x => x.BirthDate, "", new { @class = "field-validation" })
                    </div>

                    <!-- Age -->
                    <div class="field-group">
                        @Html.LabelFor(x => x.Age, "Age", new { @class = "field-label" })
                        @Html.TextBoxFor(x => x.Age, new { @class = "field-input", placeholder = "e.g. 28" })
                        @Html.ValidationMessageFor(x => x.Age, "", new { @class = "field-validation" })
                    </div>

                    <!-- Profile Picture -->
                    <div class="field-group">
                        @Html.LabelFor(x => x.PictureFile, "Profile Picture", new { @class = "field-label" })
                        <div class="file-field-wrap">
                            @if (!string.IsNullOrEmpty(Model.Picture))
                            {
                                <div class="current-picture-wrap">
                                    <img src="@Model.Picture" alt="Current picture" />
                                    <span class="current-picture-label">Current picture — upload a new one to replace</span>
                                </div>
                            }
                            @Html.TextBoxFor(x => x.PictureFile, new { @class = "field-input", type = "file", accept = "image/*" })
                        </div>
                        @Html.ValidationMessageFor(x => x.PictureFile, "", new { @class = "field-validation" })
                    </div>

                    <!-- Marital Status -->
                    <div class="field-group">
                        <span class="field-label">Marital Status</span>
                        <label class="toggle-wrap" for="MaritalStatus">
                            @Html.CheckBoxFor(x => x.MaritalStatus, new { id = "MaritalStatus" })
                            <span class="toggle-label">Married</span>
                        </label>
                        @Html.ValidationMessageFor(x => x.MaritalStatus, "", new { @class = "field-validation" })
                    </div>

                    <!-- Submit -->
                    <button type="submit" class="btn-update">
                        <i class="fa fa-refresh"></i>
                        Update Client
                    </button>

                </div>
            </div>

            <!-- ── Right Panel: Event List ── -->
            <div class="panel">
                <div class="panel-header">
                    <div class="panel-title">
                        <div class="panel-title-icon" style="background:rgba(233,30,140,.12);color:#f472b6;">
                            <i class="fa fa-calendar"></i>
                        </div>
                        Event List
                    </div>
                    <a href="#" id="btnPlus" class="btn-add-event">
                        <i class="fa fa-plus"></i>
                        Add Event
                    </a>
                </div>
                <div class="panel-body">
                    <div id="eventContainer">
                        @foreach (var item in Model.EventList)
                        {
                            @Html.Action("AddNewEvent", "Clients", new { id = item })
                        }
                    </div>
                </div>
            </div>

        </div>

        <!-- Message / Feedback -->
        <div class="row mt-3">
            <div id="msg"></div>
        </div>
    }
</div>

@section scripts {
    <script src="~/Scripts/jquery.unobtrusive-ajax.js"></script>
    <script>
        <script src="~/Scripts/jquery.unobtrusive-ajax.js"></script>
    <script>
        $("#form0").attr("enctype", "multipart/form-data");
        function clearAll() {
            $("#form0").trigger("reset");
    }
    </script>
    </script>
}
